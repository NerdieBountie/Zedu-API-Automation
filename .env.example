# ──────────────────────────────────────────────
# Zedu API Test Suite — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ──────────────────────────────────────────────

# Base API URL (no trailing slash)
BASE_URL=https://api.zedu.chat

# A pre-existing valid user account for login tests
TEST_EMAIL=your_email@example.com
TEST_PASSWORD=YourPassword123!

